"Astral_hands":{
	"information":{
        "authors":"Un1corn",
        "name":"Don't Select If You Don't Want Driver Hands",
        "value":6969
	},
	"slotType" : "Astral_hands",
	"flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["Astral_driver_arm_L", ["Astral_ahands"]]
		["Astral_driver_arm_R", ["Astral_ahands"]]
	],
	"props": [
		["func", "mesh", "idRef:", "idX:", "idY:", "baseRotation", "rotation", "translation", "min", "max", "offset", "multiplier"]
		//hands (Can't animation)
		//["steering", "Astral_driver_arm_L", "a17","a18","a13", {"x":90, "y":0 "z":0}, {"x": 0, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 0, 0, 1]
        //["steering", "Astral_driver_arm_R", "a17","a18","a13", {"x":90, "y":0 "z":0}, {"x": 0, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 0, 0, 1]
		//["steering", "Astral_arm_L_b", "dsh1","dsh3","dsh2", {"x":114.514, "y":0 "z":190}, {"x":-5, "y":-10, "z":5}, {"x":0.04, "y":0.08, "z":-0.01}, -6, 1.5, 0, 0.1, {"baseTranslation":{"x":0.025, "y":-0.255, "z":-0.05}}]
		//["steering", "Astral_arm_R_s", "a50","a49","driverref", {"x":195, "y":180 "z":8.5}, {"x":-5, "y":-1, "z":0}, {"x":0, "y":0.1, "z":0.005}, -1.5, 6, 0, 0.1, {"baseTranslation":{"x":-0, "y":0.442, "z":-0.073}}]
        //["steering", "Astral_arm_R_u", "a50","a49","driverref", {"x":188, "y":180 "z":12}, {"x":-8, "y":-2, "z":0}, {"x":0.007, "y":0.1, "z":0.02}, -1.5, 6, 0, 0.1, {"baseTranslation":{"x":-0, "y":0.442, "z":-0.103}}]
		//["steering", "Astral_arm_R_b", "dsh1","dsh3","dsh2", {"x":114.514, "y":0 "z":170}, {"x": 5, "y":-10, "z":5}, {"x":0.04, "y":-0.08, "z":0.01}, -1.5, 6, 0, 0.1, {"baseTranslation":{"x":-0.025, "y":-0.255, "z":-0.05}}]
	],
	"nodes":[
        ["id", "posX", "posY", "posZ"],
        {"nodeMaterial":"|NM_METAL"},
        {"collision":true},
        {"selfCollision":false},
		//--Animated Hands--
		//driver arms
		{"nodeWeight":1},
		{"group":"Astral_ahands"},
		["darm1l", 0.512,  0.221, 0.794],
		["darm1r", 0.148,  0.221, 0.794],
		["darm2l", 0.512,  0.072, 0.657],
		["darm2r", 0.148,  0.072, 0.657],
		["darm3l", 0.512, -0.163, 0.737],
		["darm3r", 0.148, -0.163, 0.737],
		//rigidifier
		["darmrl", 0.512, -0.01, 0.842],
		["darmrr", 0.148, -0.01, 0.842],
		//override
		{"nodeWeight":7},
		{"group":""},
		["driverref",  0.330, 0.225, 0.755],
        {"collision":true},
        {"selfCollision":true},
        {"frictionCoef":0.5},
    ],
    "beams":[
        ["id1:", "id2:"],
        //--Animated Hands--
		//arms
		{"beamSpring":65000,"beamDamp":150},
		{"beamDeform":"FLT_MAX","beamStrength":"FLT_MAX"},
		["darm1l", "darm2l"],
		["darm2l", "darm3l"],
		["darm1r", "darm2r"],
		["darm2r", "darm3r"],
		{"beamSpring":15000,"beamDamp":150},
		["darm1l", "darm2r"],
		["darm2l", "darm3r"],
		["darm1r", "darm2l"],
		["darm2r", "darm3l"],
		["darm1l", "darm3l"],
		["darm1r", "darm3r"],
		//shouders
		["darm1l", "darm1r"],
		//connect to body
		{"beamSpring":65000,"beamDamp":150},
		["darm1l", "a50"],
		["darm1l", "driverref"],
		["darm1l", "stwr"],
		["darm2l", "a50"],
		["darm2l", "driverref"],
		["darm1r", "a50"],
		["darm1r", "driverref"],
		["darm1r", "stwr"],
		["darm2r", "a50"],
		["darm2r", "driverref"],
		//rigidifier
		{"beamSpring":25000,"beamDamp":250},
		["darmrl", "darm1l"],
		["darmrl", "darm2l"],
		["darmrl", "darm3l"],
		["darmrr", "darm1r"],
		["darmrr", "darm2r"],
		["darmrr", "darm3r"],
		["darmrl", "darmrr", {"beamSpring":15000,"beamDamp":250},],
		//hands to steering wheel
		["darm3l", "stw1l"],
		["darm3l", "stw2l"],
		["darm3l", "stw1r"],
		["darm3l", "stw2r"],
		["darmrl", "stw1l"],
		["darmrl", "stw2l"],
		["darm3r", "stw1r"],
		["darm3r", "stw2r"],
		["darm3r", "stw1l"],
		["darm3r", "stw2l"],
		["darmrr", "stw1r"],
		["darmrr", "stw2r"],
		//arm damping
		{"beamSpring":0,"beamDamp":50},
		["darm2l","a49"],
		["darm2l","a50"],
		["darm2l","coref"],
		["darmrl","a49"],
		["darmrl","a50"],
		["darmrl","coref"],
		["darm2r","a49"],
		["darm2r","a50"],
		["darm2r","coref"],
		["darmrr","a49"],
		["darmrr","a50"],
		["darmrr","coref"],
    ],
},
"Astral_strwheel":{
	"information":{
        "authors":"Un1corn",
        "name":"Fanatec ClubSport 320mm Alcantara",
        "value":320
	},
	"slotType" : "Astral_strwheel",
	"slots"	: [
		["type", "default", "description"],
		["Astral_strwheel_hub", "Astral_strwheel_hub", "Wheel Hub"],
	],
	"flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["Astral_strwrod", ["Astral_dash","Astral_chassis"]],
	],
	"variables": [
		["name", "type", "unit", "category", "default", "min", "max", "title", "description"],
        ["$steeringAngle", "range", "Degrees", "Steering", 0, -5, 5, "Steering Column Angle", "Adjust the angle of steering wheel", {"stepDis":1, "subCategory":"Steering Position"}],
		["$steeringDist", "range", "mm", "Steering", 0, -20, 40, "Steering Wheel Spacer", "Adjust the distance of steering wheel", {"stepDis":20, "minDis":0, "maxDis":60, "subCategory":"Steering Position"}],
    ],
	"props": [
		["func", "mesh", "idRef:", "idX:", "idY:", "baseRotation", "rotation", "translation", "min", "max", "offset", "multiplier"]
		//steering wheel
        ["steering", "$='Astral_steering_rim_' .. $steeringDist", "dsh1", "dsh3", "dsh2", {"x":"$=80-$steeringAngle", "y":0 "z":180}, {"x":0, "y":-1, "z":0}, {"x":0, "y":0, "z":0}, "$=-$steer_lock", "$steer_lock", 0, 1]
		//QR
		["steering", "Astral_steering_QR", "dsh1","dsh3","dsh2", {"x":"$=80-$steeringAngle", "y":0 "z":180}, {"x":0, "y":-1, "z":0}, {"x":0, "y":0, "z":0}, "$=-$steer_lock", "$steer_lock", 0, 1]
		["steering", "Astral_shift", "dsh1","dsh3","dsh2", {"x":"$=-80+$steeringAngle", "y":0 "z":0}, {"x":0, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 1, 0, 1]
		//Shaft
		["steering", "Astral_steering_shaft", "dsh1","dsh3","dsh2", {"x":"$=80-$steeringAngle", "y":0 "z":180}, {"x":0, "y":-1, "z":0}, {"x":0, "y":0, "z":0}, "$=-$steer_lock", "$steer_lock", 0, 1]
	],
	"nodes":[
        ["id", "posX", "posY", "posZ"],
        {"nodeMaterial":"|NM_METAL"},
        {"collision":true},
        {"selfCollision":false},
		//--Steering Torsion Hydro--
        //wheel
        {"frictionCoef":0.5},
        {"nodeWeight":0.3},
        {"group":""},
        ["stw1l", 0.49, "$=-0.192+($steeringDist/1000)", 0.93],
        ["stw1r", 0.17, "$=-0.192+($steeringDist/1000)", 0.93],
        ["stw2l", 0.49, "$=-0.192+($steeringDist/1000)", 0.61],
        ["stw2r", 0.17, "$=-0.192+($steeringDist/1000)", 0.61],
        //rigidifier and column
		{"group":""},
        {"nodeWeight":1},
        ["stwr",  0.330, "$= 0    +($steeringDist/1000)", 0.77],
        ["stwc",  0.330, "$=-0.384+($steeringDist/1000)", 0.77],
        {"collision":true},
        {"selfCollision":true},
        {"frictionCoef":0.5},
    ],
    "beams":[
        ["id1:", "id2:"],
        //--Steering Torsion Hydro--
        //main shape
        {"beamSpring":151000,"beamDamp":50},
        {"beamDeform":"FLT_MAX","beamStrength":"FLT_MAX"},
        ["stw1l","stw1r"],
        ["stw1r","stw2r"],
        ["stw2r","stw2l"],
        ["stw2l","stw1l"],
        ["stw1r","stw2l"],
        ["stw1l","stw2r"],
        //rigidifier
        {"beamSpring":101000,"beamDamp":50},
        ["stwr","stw1l"],
        ["stwr","stw1r"],
        ["stwr","stw2l"],
        ["stwr","stw2r"],
        ["stwc","stw1l"],
        ["stwc","stw1r"],
        ["stwc","stw2l"],
        ["stwc","stw2r"],
        ["stwr","stwc"],
		//wheel damping
		{"beamSpring":0,"beamDamp":50},
		["stw1l","a49"],
		["stw1l","a50"],
		["stw1l","coref"],
		["stw2l","a49"],
		["stw2l","a50"],
		["stw2l","coref"],
		["stw1r","a49"],
		["stw1r","a50"],
		["stw1r","coref"],
		["stw2r","a49"],
		["stw2r","a50"],
		["stw2r","coref"],
		//connect to steering column and chassis
		{"beamSpring":1001000,"beamDamp":100},
		["stwr","a49"],
		["stwr","a50"],
		["stwr","driverref"],
		["stwr","coref"],
		["stwr","a83"],
		["stwr","a81"],
		["stwr","a54"],
		["stwr","a47"],
		["stwc","a49"],
		["stwc","a50"],
		["stwc","driverref"],
		["stwc","coref"],
		["stwc","a83"],
		["stwc","a53"],
		["stwc","a54"],
		["stwc","rc2l"],
		//connect to cable
		{"beamSpring":200,"beamDamp":4},
		["stw1l","cab3"],
		["stw2l","cab3"],
		["stw1r","cab3"],
		["stw2r","cab3"],
		["stw1l","cabr"],
		["stw2l","cabr"],
		["stw1r","cabr"],
		["stw2r","cabr"],
    ],
    "triangles":[
        ["id1:", "id2:", "id3:"],
        {"dragCoef":0},
		{"liftCoef":0, "stallAngle":0},
        {"groundModel":"metal"},
        //--Steering Torsion Hydro--
        //wheel
        ["stw1l", "stw1r", "stw2r"],
        ["stw1l", "stw2r", "stw2l"],
		{"dragCoef":""},
		{"liftCoef":"", "stallAngle":""},
    ],
	"torsionHydros": [
        ["id1:","id2:","id3:","id4:"],
        {"spring":1500, "damp":1.5, "deform":9999999999999, "strength":99999999999999},
        ["stw1l","stwr","stwc","a54", {"factor":"$=(pi/180)*(-$steer_lock)","inRate":24,"outRate":24,"inputSource":"steeringUnassisted"}],
    ],
},
"Astral_strwheel_hub":{
	"information":{
        "authors":"Un1corn",
        "name":"Simagic Neo X Hub",
        "value":320
	},
	"slotType" : "Astral_strwheel_hub",
	"props": [
		["func", "mesh", "idRef:", "idX:", "idY:", "baseRotation", "rotation", "translation", "min", "max", "offset", "multiplier"]
		//Neo X Hub
		["steering", "$='Astral_steering_NeoX_'..$steeringDist", "dsh1","dsh3","dsh2", {"x":"$=80-$steeringAngle", "y":0 "z":180}, {"x":0, "y":-1, "z":0}, {"x":0, "y":0, "z":0}, "$=-$steer_lock", "$steer_lock", 0, 1]
	],
},
"Astral_shifter_paddle":{
	"information":{
        "authors":"Un1corn",
        "name":"Paddle Shifter",
        "value":320
	},
	"slotType" : "Astral_shifter",
	"flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
		["Astral_paddle_mount", ["Astral_dash", "Astral_chassis", "Astral_chassis_F"]],
		["Astral_sequential", ["Astral_chassis"]],
	],
	"controller": [
		["fileName"],
		["propAnimation/sequentialLever", {"name":"sequentialLever"}]
	],
    "sequentialLever": {
        "shiftSoundNode:":["dsh1"],
        "shiftSoundEventSequentialGearUp": "file:>art>sound>shift>shift_up.wav",
        "shiftSoundEventSequentialGearDown": "file:>art>sound>shift>shift_down.wav",
        "shiftSoundVolumeSequentialGearUp": 1.5,
        "shiftSoundVolumeSequentialGearDown": 1
	}
	"props": [
		["func", "mesh", "idRef:", "idX:", "idY:", "baseRotation", "rotation", "translation", "min", "max", "offset", "multiplier"]
		//paddle shifter
		["sequentialLeverY", "Astral_paddle", "dsh1","dsh3","dsh2", {"x":"$=-80+$steeringAngle", "y":0, "z":0}, {"x":0, "y":0, "z":5}, {"x":0.15, "y":-0.075, "z":0}, -1, 1, 0, 1]
		["sequentialLeverY", "Astral_paddle_control", "dsh1","dsh3","dsh2", {"x":"$=-80+$steeringAngle", "y":0 "z":0}, {"x":0, "y":0, "z":0}, {"x":0, "y":0.0, "z":0}, 0, 0, 0, 1]
		//aux shifter
        ["sequentialLeverY", "Astral_sfstick_aux", "a17","a18","a13", {"x":75, "y":0 "z":0}, {"x":10, "y":0, "z":0}, {"x":0, "y":0, "z":0}, -1, 1, 0, 0.8]
		//linkage
		["sequentialLeverY", "Astral_paddle_link", "dsh1","dsh3","dsh2", {"x":"$=-80+$steeringAngle", "y":0 "z":0}, {"x":0, "y":0, "z":0}, {"x":0, "y":0.1, "z":-0.0014}, -1, 1, 0, 1]
		["sequentialLeverY", "Astral_sfstick_link", "a17","a18","a13", {"x":90, "y":0 "z":0}, {"x":0, "y":0, "z":0}, {"x":0, "y":-0.05, "z":0.005}, -1, 1, 0, 0.8]
		//cylinder
		["sequentialLeverY", "Astral_sequential_cylinder", "a17","a18","a13", {"x":90, "y":0 "z":0}, {"x":0, "y":0, "z":0}, {"x":0, "y":-0.008, "z":-0.002}, -1, 1, 0, 0.8]
	]
},
