"Astral_pedal":{
	"information":{
        "authors":"Un1corn",
        "name":"Lightweight Pedal Box",
        "value":320
	},
	"slotType" : "Astral_pedal",
	"flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
        ["Astral_pedal", ["Astral_pedal"]]
	],
	"props": [
		["func", "mesh", "idRef:", "idX:", "idY:", "baseRotation", "rotation", "translation", "min", "max", "offset", "multiplier"]
		//--Racing Pedals--
        ["throttle", "Astral_gas", "pd2","pd1","pd3", {"x":90, "y":0 "z":0}, {"x":10, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 1, 0, 1],
		["brake", "Astral_brake", "pd2","pd1","pd3", {"x":90, "y":0 "z":0}, {"x":8, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 1, 0, 1],
		["clutch", "Astral_clutch", "pd2","pd1","pd3", {"x":90, "y":0 "z":0}, {"x":8, "y":0, "z":0}, {"x":0, "y":0, "z":0}, 0, 1, 0, 1]
    ],
	"nodes": [       
        ["id", "posX", "posY", "posZ"],
        {"frictionCoef":0.5},
        {"collision":true},
        {"selfCollision":false},
        {"nodeMaterial":"|NM_METAL"},
		//--Pedal Box--
		{"nodeWeight":1},
		{"group":["Astral_pedal"]},
		["pd1", 0.597, -0.775, 0.16],
		["pd2", 0.136, -0.775, 0.16],
		["pd3", 0.136, -0.514, 0.16],
		["pd4", 0.597, -0.514, 0.16],
		["pdr", 0.362, -0.654, 0.28],
		{"collision":true},
		{"selfCollision":true},
		{"group":[""]}
	],
	"beams": [   
		["id1:", "id2:"], 
        {"beamPrecompression":1, "beamType":"|NORMAL", "beamLongBound":1, "beamShortBound":1},
		//--Pedal Box Steering Position--
		{"beamDeform":"FLT_MAX","beamStrength":"FLT_MAX"},
		//pedal shape
		{"beamSpring":651000,"beamDamp":50},
		["pd1", "pd2"],
		["pd2", "pd3"],
		["pd3", "pd4"],
		["pd4", "pd1"],
		//pedal crossing
		["pd1", "pd3"],
		["pd2", "pd4"],
		//rigidifier
		["pdr", "pd1"],
		["pdr", "pd2"],
		["pdr", "pd3"],
		["pdr", "pd4"],
		//mount
		{"beamSpring":651000,"beamDamp":80},
		["pd1", "a22"],
		["pd1", "a23"],
		["pd1", "a87"],
		["pd2", "a22"],
		["pd2", "a23"],
		["pd2", "a83"],
		["pd3", "a16"],
		["pd3", "a19"],
		["pd3", "a83"],
		["pd4", "a16"],
		["pd4", "a19"],
		["pd4", "a23"],
		["pd4", "a87"],
		["pd4", "a83"],
		["pd1", "a54"],
		["pd1", "a53"],
		["pd2", "a54"],
		["pd2", "a53"],
		["pd3", "a54"],
		["pd3", "a53"],
		["pd4", "a54"],
		{"optional":true},
		["pd1", "a50"],
		["pd2", "a50"],
