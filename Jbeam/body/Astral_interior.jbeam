{
"Astral_interior":{
	"information":{
        "authors":"Un1corn",
        "name":"Racing Interior",
        "value":320
	},
	"slotType" : "Astral_interior",
	"slots"	: [
		["type", "default", "description"],
		["Astral_seat", "Astral_seat2", "Driver and Seat"],
		["Astral_pedal", "Astral_pedal", "Pedal", {"coreSlot":true}],
		["Astral_onboard", "Astral_onboard", "Onboard Camera"],
		["Astral_handbrake", "Astral_handbrake", "Handbrake"],
		["Astral_strwheel", "Astral_strwheel", "Steering Wheel", {"coreSlot":true}],
		["Astral_shifter", "Astral_shifter_paddle", "Shifter", {"coreSlot":true}],
		["Astral_shiftlight", "Astral_shiftlight_BRC", "Shift Light"],
		["Astral_spare", "", "Spare Wheel"],
		["Astral_gauge", "Astral_gauge_BRC", "Gauge"],
		["Astral_tools", "Astral_tools_15", "Crew Weight Ballast"],
		["Astral_dummy", "", "Test Equipment"],
		["soundscape_horn", "soundscape_horn_6", "Horn"]
	],
	"flexbodies": [
        ["mesh", "[group]:", "nonFlexMaterials"],
		["Astral_interior", ["Astral_chassis_F","Astral_chassis","Astral_dash"]],
		["Astral_roofsheet", ["Astral_carbody"]],
		["Astral_ECU", ["Astral_chassis_F"]],
    ],
	"soundscape": [
		["name", "src"],
		{"node:":"dsh1"},
		["indicatorStart", "event:>Vehicle>Interior>Indicator>FIPA_On"],
		["indicatorStop", "event:>Vehicle>Interior>Indicator>FIPA_Off"],
		["indLoop1", "event:>Vehicle>Interior>Indicator>FIPA_Click"],
		["indLoop2", "event:>Vehicle>Interior>Indicator>FIPA_Clack"],
		["LightOn", "event:>Vehicle>Interior>Light>BM1_On"],
		["LightOff", "event:>Vehicle>Interior>Light>BM1_On"],
    ],
	"sounds": {
        "$+cabinFilterCoef": 0.2
    },
	"camerasInternal":[
        ["type", "x", "y", "z", "fov", "id1:", "id2:", "id3:", "id4:", "id5:", "id6:"],
		{"nodeWeight":1},
        {"selfCollision":false},
        {"collision":false},
        {"beamDeform":5001000},
        {"beamStrength":"FLT_MAX"},
		{"beamSpring":1001000},
        {"beamDamp":150},
		["neardash", 0.330, -0.528, 0.985, 56, "a85","a87","a83","a82","a18","a19"],
    ],
	"nodes": [       
        ["id", "posX", "posY", "posZ"],
        {"frictionCoef":0.5},
        {"collision":false},
        {"selfCollision":false},
        {"nodeMaterial":"|NM_METAL"},
		//--Dashboard for Wheel--
		{"group":["Astral_dash"]},
		{"nodeWeight":0.5},
		["dsh1", 0.330, -0.471224, 0.7436],
		["dsh2", 0.330, -0.551224, 0.7436],
		["dsh3", 0.459824, -0.471224, 0.7436],
		{"nodeWeight":0.75}
		["dsh4", 0.330,  -0.778,  0.799],
		["dsh5", -0.330, -0.778,  0.799],
		["dsh6", -0.330, -0.577,  0.799],
