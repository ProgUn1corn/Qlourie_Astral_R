        ["fh3r", -0.752, -1.201, "$=-0.02795", {"group":["Astral_hub_FR","Astral_rod_F"]}],
        ["fh3l",  0.752, -1.201, "$=-0.02795", {"group":["Astral_hub_FL","Astral_rod_F"]}],
